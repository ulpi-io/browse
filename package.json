{
  "name": "@ulpi/browse",
  "version": "2.3.3",
  "homepage": "https://browse.ulpi.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulpi-io/browse"
  },
  "dependencies": {
    "@lightpanda/browser": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@ulpi/browse": "^0.3.0",
    "better-sqlite3": "^11.0.0",
    "diff": "^7.0.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "yaml": "^2.8.3"
  },
  "bin": {
    "browse": "bin/browse"
  },
  "description": "Fast headless browser and native app automation CLI for AI coding agents. Android, iOS, and macOS.",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "dist/",
    "skill/",
    "browse-ios-runner/BrowseRunnerApp/",
    "browse-ios-runner/BrowseRunnerUITests/",
    "browse-ios-runner/project.yml",
    "browse-ios-runner/build.sh",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "browser",
    "automation",
    "playwright",
    "headless",
    "cli",
    "ai-agent",
    "claude",
    "android",
    "ios",
    "macos",
    "mobile-testing",
    "accessibility"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --format=cjs --platform=node --target=node18 --outfile=dist/browse.cjs --external:playwright --external:playwright-core --external:better-sqlite3 --external:electron --external:chromium-bidi --external:@modelcontextprotocol/sdk --banner:js='#!/usr/bin/env node\nconst __import_meta_url = require(\"url\").pathToFileURL(__filename).href;' --define:import.meta.url=__import_meta_url",
    "build:all": "bash scripts/build-all.sh",
    "dev": "tsx src/cli.ts",
    "server": "tsx src/server.ts",
    "test": "vitest run",
    "start": "tsx src/server.ts",
    "postinstall": "npx playwright install chromium",
    "benchmark": "echo 'Benchmarks moved to separate repo'"
  },
  "type": "module",
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "rebrowser-playwright": "^1.52.0"
  }
}
